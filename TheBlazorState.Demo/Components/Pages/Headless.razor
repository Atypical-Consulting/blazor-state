@page "/headless"

<PageTitle>Headless UI — TaskFlow</PageTitle>

<div class="mb-6 animate-fade-up">
    <h1 class="font-display text-2xl font-bold text-canvas-900 dark:text-canvas-50">Headless UI Components</h1>
    <p class="text-sm text-canvas-500 dark:text-canvas-500 mt-1">Unstyled, accessible components — bring your own Tailwind</p>
</div>

<!-- Toggle Section -->
<section class="animate-fade-up stagger-1 mb-8">
    <div class="bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5">
        <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider mb-4">Toggle / Switch</h2>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-3">
                <Toggle @bind-Value="DarkMode" Label="Dark mode"
                        class="@($"relative inline-flex h-6 w-11 items-center rounded-full transition-colors {(DarkMode ? "bg-signal-500" : "bg-canvas-300 dark:bg-canvas-600")}")">
                    <span class="@($"inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform {(DarkMode ? "translate-x-6" : "translate-x-1")}")" />
                </Toggle>
                <span class="text-sm text-canvas-700 dark:text-canvas-300">Dark mode: <span class="font-mono text-signal-600 dark:text-signal-400">@DarkMode</span></span>
            </div>
            <div class="flex items-center gap-3">
                <Toggle @bind-Value="Notifications" Label="Notifications"
                        class="@($"relative inline-flex h-6 w-11 items-center rounded-full transition-colors {(Notifications ? "bg-emerald-500" : "bg-canvas-300 dark:bg-canvas-600")}")">
                    <span class="@($"inline-block h-4 w-4 transform rounded-full bg-white shadow transition-transform {(Notifications ? "translate-x-6" : "translate-x-1")}")" />
                </Toggle>
                <span class="text-sm text-canvas-700 dark:text-canvas-300">Notifications: <span class="font-mono text-emerald-600 dark:text-emerald-400">@Notifications</span></span>
            </div>
        </div>
    </div>
</section>

<!-- Accordion Section -->
<section class="animate-fade-up stagger-2 mb-8">
    <div class="bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5">
        <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider mb-4">Accordion / Disclosure</h2>
        <Accordion class="divide-y divide-canvas-200 dark:divide-canvas-700 border border-canvas-200 dark:border-canvas-700 rounded-lg overflow-hidden">
            <AccordionItem DefaultOpen="true">
                <AccordionTrigger class="flex w-full items-center justify-between px-4 py-3 text-sm font-medium text-canvas-800 dark:text-canvas-200 hover:bg-canvas-50 dark:hover:bg-canvas-800 transition-colors">
                    What is TheBlazorState?
                </AccordionTrigger>
                <AccordionPanel class="px-4 pb-3 text-sm text-canvas-600 dark:text-canvas-400">
                    A source-generated state management library for Blazor that uses [Persist] and [Shared] attributes to automatically handle state persistence, restoration, and cross-tab synchronization.
                </AccordionPanel>
            </AccordionItem>
            <AccordionItem>
                <AccordionTrigger class="flex w-full items-center justify-between px-4 py-3 text-sm font-medium text-canvas-800 dark:text-canvas-200 hover:bg-canvas-50 dark:hover:bg-canvas-800 transition-colors">
                    What are headless components?
                </AccordionTrigger>
                <AccordionPanel class="px-4 pb-3 text-sm text-canvas-600 dark:text-canvas-400">
                    Headless components provide behavior (keyboard navigation, ARIA, focus management) without any styling. You bring your own Tailwind classes — full control over the look while getting accessibility for free.
                </AccordionPanel>
            </AccordionItem>
            <AccordionItem>
                <AccordionTrigger class="flex w-full items-center justify-between px-4 py-3 text-sm font-medium text-canvas-800 dark:text-canvas-200 hover:bg-canvas-50 dark:hover:bg-canvas-800 transition-colors">
                    How does the API work?
                </AccordionTrigger>
                <AccordionPanel class="px-4 pb-3 text-sm text-canvas-600 dark:text-canvas-400">
                    Each component is a family of sub-components (e.g., Dialog + DialogTrigger + DialogContent + DialogTitle + DialogClose). They share state via CascadingValue and you style them with the class parameter.
                </AccordionPanel>
            </AccordionItem>
        </Accordion>
    </div>
</section>

<!-- Tabs Section -->
<section class="animate-fade-up stagger-3 mb-8">
    <div class="bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5">
        <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider mb-4">Tabs</h2>
        <TabGroup>
            <TabList class="flex gap-1 border-b border-canvas-200 dark:border-canvas-700 mb-4">
                <Tab class="px-4 py-2 text-sm text-canvas-500 dark:text-canvas-400 transition-colors hover:text-canvas-800 dark:hover:text-canvas-200"
                     ActiveClass="border-b-2 border-signal-500 text-signal-700 dark:text-signal-400 font-semibold">
                    General
                </Tab>
                <Tab class="px-4 py-2 text-sm text-canvas-500 dark:text-canvas-400 transition-colors hover:text-canvas-800 dark:hover:text-canvas-200"
                     ActiveClass="border-b-2 border-signal-500 text-signal-700 dark:text-signal-400 font-semibold">
                    Notifications
                </Tab>
                <Tab class="px-4 py-2 text-sm text-canvas-500 dark:text-canvas-400 transition-colors hover:text-canvas-800 dark:hover:text-canvas-200"
                     ActiveClass="border-b-2 border-signal-500 text-signal-700 dark:text-signal-400 font-semibold"
                     Disabled="true">
                    Privacy (disabled)
                </Tab>
            </TabList>
            <TabPanels>
                <TabPanel class="text-sm text-canvas-700 dark:text-canvas-300">
                    <p>General settings panel. This tab was selected by default.</p>
                    <p class="mt-2 text-canvas-500 dark:text-canvas-500">Use Arrow Left/Right keys to navigate between tabs.</p>
                </TabPanel>
                <TabPanel class="text-sm text-canvas-700 dark:text-canvas-300">
                    <p>Notification preferences. Toggle email and push notifications here.</p>
                </TabPanel>
                <TabPanel class="text-sm text-canvas-700 dark:text-canvas-300">
                    <p>This panel should never be visible because its tab is disabled.</p>
                </TabPanel>
            </TabPanels>
        </TabGroup>
    </div>
</section>

<!-- Dropdown Section -->
<section class="animate-fade-up stagger-4 mb-8">
    <div class="bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5">
        <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider mb-4">Dropdown / Menu</h2>
        <div class="flex items-center gap-4">
            <Dropdown class="relative">
                <DropdownTrigger class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-canvas-100 dark:bg-canvas-800 text-canvas-700 dark:text-canvas-300 hover:bg-canvas-200 dark:hover:bg-canvas-700 transition-colors">
                    Actions
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </DropdownTrigger>
                <DropdownPanel class="absolute mt-1 w-48 bg-white dark:bg-canvas-800 border border-canvas-200 dark:border-canvas-700 rounded-lg shadow-lg py-1 z-50">
                    <DropdownItem OnClick="HandleEdit" class="block w-full text-left px-4 py-2 text-sm text-canvas-700 dark:text-canvas-300 hover:bg-canvas-50 dark:hover:bg-canvas-700 transition-colors">
                        Edit
                    </DropdownItem>
                    <DropdownItem OnClick="HandleDuplicate" class="block w-full text-left px-4 py-2 text-sm text-canvas-700 dark:text-canvas-300 hover:bg-canvas-50 dark:hover:bg-canvas-700 transition-colors">
                        Duplicate
                    </DropdownItem>
                    <DropdownSeparator class="my-1 border-t border-canvas-200 dark:border-canvas-700" />
                    <DropdownItem OnClick="HandleDelete" class="block w-full text-left px-4 py-2 text-sm text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-900/20 transition-colors">
                        Delete
                    </DropdownItem>
                </DropdownPanel>
            </Dropdown>
            <span class="text-sm text-canvas-500 dark:text-canvas-500 font-mono">Last action: @_lastAction</span>
        </div>
    </div>
</section>

<!-- Dialog Section -->
<section class="animate-fade-up stagger-5 mb-8">
    <div class="bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5">
        <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider mb-4">Dialog / Modal</h2>
        <button @onclick="() => _dialogOpen = true"
                class="px-4 py-2 rounded-lg text-sm font-medium bg-rose-500 text-white hover:bg-rose-600 transition-colors">
            Delete Item
        </button>
        <span class="ml-4 text-sm text-canvas-500 dark:text-canvas-500 font-mono">Dialog open: @_dialogOpen</span>
    </div>
</section>

@* Dialog rendered at page root to avoid ancestor transforms breaking fixed positioning *@
<Dialog @bind-Open="_dialogOpen">
    <DialogOverlay class="fixed inset-0 bg-black/50 z-40" />
    <DialogContent class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 shadow-xl max-w-md w-full p-6">
            <DialogTitle class="font-display text-lg font-bold text-canvas-900 dark:text-canvas-50">
                Confirm Delete
            </DialogTitle>
            <p class="mt-2 text-sm text-canvas-600 dark:text-canvas-400">
                Are you sure you want to delete this item? This action cannot be undone.
            </p>
            <div class="mt-6 flex gap-3 justify-end">
                <DialogClose class="px-4 py-2 rounded-lg text-sm font-medium bg-canvas-100 dark:bg-canvas-800 text-canvas-700 dark:text-canvas-300 hover:bg-canvas-200 dark:hover:bg-canvas-700 transition-colors">
                    Cancel
                </DialogClose>
                <button @onclick="ConfirmDelete"
                        class="px-4 py-2 rounded-lg text-sm font-medium bg-rose-500 text-white hover:bg-rose-600 transition-colors">
                    Delete
                </button>
            </div>
        </div>
    </DialogContent>
</Dialog>
