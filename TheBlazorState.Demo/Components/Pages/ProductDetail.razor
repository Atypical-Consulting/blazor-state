@page "/product/{ProductId:int}"
@rendermode InteractiveServer

<PageTitle>Product</PageTitle>

<h1>@(Page?.Product?.Name ?? "Loading...")</h1>

@if (Page?.Product is not null)
{
    <p>@Page.Product.Description</p>
    <p><strong>@Page.Product.Price.ToString("C")</strong></p>

    <button class="btn @(Page.IsInWishlist ? "btn-danger" : "btn-outline-primary")"
            @onclick="ToggleWishlist">
        @(Page.IsInWishlist ? "Remove from wishlist" : "Add to wishlist")
    </button>

    @if (Page.Reviews is not null)
    {
        <h2>Reviews (@Page.Reviews.TotalCount)</h2>
        <p>Average: @Page.Reviews.AverageRating / 5</p>
    }
}
