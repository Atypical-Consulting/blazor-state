@page "/weather"
@rendermode InteractiveServer

<PageTitle>Weather Dashboard</PageTitle>

<h1>Weather Dashboard</h1>

@if (Forecasts is null)
{
    <p><em>Loading forecasts...</em></p>
}
else
{
    @if (ForecastsMeta.IsStale)
    {
        <div class="alert alert-warning">
            Data is stale (last updated @ForecastsMeta.LastUpdated.LocalDateTime).
            <button class="btn btn-sm btn-outline-warning" @onclick="Refresh">
                Refresh
            </button>
        </div>
    }

    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Temp (C)</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Forecasts)
            {
                <tr>
                    <td>@f.Date.ToShortDateString()</td>
                    <td>@f.TemperatureC</td>
                    <td>@f.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}
