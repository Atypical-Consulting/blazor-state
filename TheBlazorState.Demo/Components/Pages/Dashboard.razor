@page "/"

<PageTitle>Dashboard — TaskFlow</PageTitle>

<div class="mb-8 animate-fade-up flex items-start justify-between relative z-10">
    <div>
        <h1 class="font-display text-2xl font-bold text-canvas-900 dark:text-canvas-50">Dashboard</h1>
        <p class="text-sm text-canvas-500 dark:text-canvas-500 mt-1">Project overview &amp; kanban board</p>
    </div>
    <Dropdown class="relative">
        <DropdownTrigger class="inline-flex items-center gap-2.5 pl-3.5 pr-3 py-2 rounded-lg text-sm font-medium
                                bg-white dark:bg-canvas-800 border border-canvas-200 dark:border-canvas-700
                                text-canvas-700 dark:text-canvas-300
                                hover:border-canvas-300 dark:hover:border-canvas-600
                                shadow-sm hover:shadow transition-all duration-150">
            <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: @Project.SelectedProject.Color"></span>
            @Project.SelectedProject.Name
            <svg class="w-4 h-4 text-canvas-400 dark:text-canvas-500 -mr-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </DropdownTrigger>
        <DropdownPanel class="absolute right-0 mt-1.5 w-52 bg-white dark:bg-canvas-800 border border-canvas-200 dark:border-canvas-700 rounded-xl shadow-lg shadow-canvas-900/8 dark:shadow-canvas-950/30 py-1.5 z-[100]">
            @foreach (var project in ProjectSvc.GetAll())
            {
                var p = project;
                var isActive = Project.SelectedProject.Id == p.Id;
                <DropdownItem OnClick="() => SelectProject(p)"
                              class="@($"flex items-center gap-2.5 w-full text-left px-3.5 py-2 text-sm transition-colors duration-100 {(isActive ? "bg-canvas-50 dark:bg-canvas-700/50 text-canvas-900 dark:text-canvas-100 font-medium" : "text-canvas-600 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-700/40 hover:text-canvas-900 dark:hover:text-canvas-200")}")">
                    <span class="w-2 h-2 rounded-full flex-shrink-0 @(isActive ? "ring-2 ring-offset-1 dark:ring-offset-canvas-800 ring-signal-400/50" : "")" style="background-color: @p.Color"></span>
                    @p.Name
                    @if (isActive)
                    {
                        <svg class="w-3.5 h-3.5 ml-auto text-signal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    }
                </DropdownItem>
            }
        </DropdownPanel>
    </Dropdown>
</div>

<TryItHint Id="dashboard" Text="Switch projects with the dropdown. Wait 2 minutes for TTL expiry (a stale banner appears), or refresh the page to see prerender cache restore. Move tasks between columns — changes persist in localStorage." />

@if (Stats is null || BoardState is null)
{
    <div class="flex items-center gap-3 text-canvas-400 dark:text-canvas-600 py-12">
        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
        <span class="font-mono text-sm">Loading dashboard...</span>
    </div>
}
else
{
    @if (StatsMeta.IsStale)
    {
        <div class="mb-6 flex items-center gap-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-300 px-4 py-3 rounded-lg text-sm animate-fade-up">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <span>Data is stale — last updated <span class="font-mono">@StatsMeta.LastUpdated.LocalDateTime.ToString("HH:mm:ss")</span></span>
            <button @onclick="Refresh" class="ml-auto font-medium text-amber-700 dark:text-amber-400 hover:underline underline-offset-2">Refresh</button>
        </div>
    }

    @if (StatsMeta.WasRestored || BoardStateMeta.WasRestored)
    {
        <div class="mb-6 flex items-center gap-2 text-xs text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 px-3 py-2 rounded-lg animate-fade-up">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="font-mono">
                @if (StatsMeta.WasRestored && BoardStateMeta.WasRestored)
                {
                    @:Stats restored from prerender cache — Board restored from localStorage
                }
                else if (StatsMeta.WasRestored)
                {
                    @:Stats restored from prerender cache — no redundant API call
                }
                else
                {
                    @:Board restored from localStorage — instant render
                }
            </span>
        </div>
    }

    <!-- Stat Cards -->
    <div class="grid grid-cols-3 gap-5 mb-8">
        <div class="animate-fade-up stagger-1 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5 relative overflow-hidden group hover:border-canvas-300 dark:hover:border-canvas-700 transition-colors">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-canvas-200 dark:bg-canvas-700"></div>
            <p class="text-xs font-mono font-medium text-canvas-400 dark:text-canvas-500 uppercase tracking-wider">Total Tasks</p>
            <p class="font-display text-3xl font-bold text-canvas-900 dark:text-canvas-50 mt-2">@Stats.TotalTasks</p>
        </div>
        <div class="animate-fade-up stagger-2 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5 relative overflow-hidden group hover:border-signal-300 dark:hover:border-signal-800 transition-colors">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-signal-400"></div>
            <p class="text-xs font-mono font-medium text-canvas-400 dark:text-canvas-500 uppercase tracking-wider">In Progress</p>
            <p class="font-display text-3xl font-bold text-signal-600 dark:text-signal-400 mt-2">@Stats.InProgress</p>
        </div>
        <div class="animate-fade-up stagger-3 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5 relative overflow-hidden group hover:border-emerald-300 dark:hover:border-emerald-800 transition-colors">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-emerald-400"></div>
            <p class="text-xs font-mono font-medium text-canvas-400 dark:text-canvas-500 uppercase tracking-wider">Completed</p>
            <p class="font-display text-3xl font-bold text-emerald-600 dark:text-emerald-400 mt-2">@Stats.Completed</p>
        </div>
    </div>

    <!-- Kanban Board -->
    <div class="mb-4 animate-fade-up stagger-3">
        <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider">Board</h2>
    </div>

    <div class="grid grid-cols-3 gap-5 mb-8 animate-fade-up stagger-4">
        @{ RenderColumn("To Do", BoardState.ToDo, "todo", null, "inprogress"); }
        @{ RenderColumn("In Progress", BoardState.InProgress, "inprogress", "todo", "done"); }
        @{ RenderColumn("Done", BoardState.Done, "done", "inprogress", null); }
    </div>

    <!-- Recent Activity -->
    <div class="animate-fade-up stagger-5 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 overflow-hidden mb-8">
        <div class="px-5 py-4 border-b border-canvas-100 dark:border-canvas-800">
            <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider">Recent Activity</h2>
        </div>
        <ul class="divide-y divide-canvas-100 dark:divide-canvas-800">
            @foreach (var activity in Stats.RecentActivity)
            {
                <li class="px-5 py-3 flex items-center justify-between hover:bg-canvas-50 dark:hover:bg-canvas-800/50 transition-colors">
                    <div>
                        <span class="text-sm text-canvas-800 dark:text-canvas-200 font-medium">@activity.TaskTitle</span>
                        <span class="text-sm text-canvas-400 dark:text-canvas-500 ml-1.5">@activity.Action by @activity.Actor</span>
                    </div>
                    <span class="text-xs font-mono text-canvas-400 dark:text-canvas-600">@FormatRelativeTime(activity.Timestamp)</span>
                </li>
            }
        </ul>
    </div>

    <div class="grid grid-cols-2 gap-5">
        <CodeSnippet Title="View source: Persist + TTL + Prerender Cache"
                     Code="<span class='text-signal-400'>[Persist(TimeToLive = &quot;00:02:00&quot;)]</span>
<span class='text-emerald-400'>public partial</span> DashboardData? <span class='text-sky-400'>Stats</span> { get; set; }

<span class='text-canvas-500'>// ConfigureState — runs during OnInitialized</span>
<span class='text-emerald-400'>partial void</span> ConfigureState(__StateContext ctx)
{
    ctx.Stats
        .<span class='text-sky-400'>KeySuffix</span>(Project.SelectedProject.Id)
        .<span class='text-sky-400'>LoadFrom</span>(<span class='text-emerald-400'>async</span> () =&gt;
            <span class='text-emerald-400'>await</span> StatsService.GetDashboardAsync(id));
}" />
        <CodeSnippet Title="View source: Persist + LocalStorage"
                     Code="<span class='text-signal-400'>[Persist(TimeToLive = &quot;00:05:00&quot;)]</span>
<span class='text-emerald-400'>public partial</span> BoardData? <span class='text-sky-400'>BoardState</span> { get; set; }

<span class='text-emerald-400'>partial void</span> ConfigureState(__StateContext ctx)
{
    ctx.BoardState
        .<span class='text-sky-400'>KeySuffix</span>(Project.SelectedProject.Id)
        .<span class='text-sky-400'>LoadFrom</span>(<span class='text-emerald-400'>async</span> () =&gt;
            <span class='text-emerald-400'>await</span> TaskService.GetBoardAsync(id));
    ctx.BoardState.<span class='text-sky-400'>Storage</span> = StorageStrategy.<span class='text-signal-400'>LocalStorage</span>();
}" />
    </div>
}

@{ void RenderColumn(string title, List<TaskItem> tasks, string columnId, string? prevColumn, string? nextColumn)
{
    var accentClass = columnId switch
    {
        "todo" => "bg-canvas-300 dark:bg-canvas-600",
        "inprogress" => "bg-signal-400",
        "done" => "bg-emerald-400",
        _ => "bg-canvas-400"
    };
    <div class="bg-canvas-100 dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-4 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-0.5 @accentClass"></div>
        <div class="flex items-center justify-between mb-3 mt-1">
            <h3 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider">@title</h3>
            <span class="text-xs font-mono text-canvas-400 dark:text-canvas-600 bg-white dark:bg-canvas-800 px-2 py-0.5 rounded-md border border-canvas-200 dark:border-canvas-700">@tasks.Count</span>
        </div>
        <div class="space-y-2">
            @foreach (var task in tasks)
            {
                <div class="bg-white dark:bg-canvas-800 rounded-lg border border-canvas-200 dark:border-canvas-700 p-3 hover:border-canvas-300 dark:hover:border-canvas-600 transition-colors group">
                    <p class="text-sm font-medium text-canvas-800 dark:text-canvas-200 mb-2.5">@task.Title</p>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="@($"text-[10px] font-mono px-1.5 py-0.5 rounded font-medium tracking-wide {PriorityClasses(task.Priority)}")">@task.Priority</span>
                            <span class="@($"w-5 h-5 rounded-full text-white text-[10px] flex items-center justify-center font-medium {AvatarColor(task.AssigneeInitials)}")" title="@task.AssigneeName">@task.AssigneeInitials</span>
                        </div>
                        <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                            @if (prevColumn is not null)
                            {
                                var prev = prevColumn;
                                <button @onclick="() => MoveTask(task, columnId, prev)"
                                        class="text-canvas-400 dark:text-canvas-500 hover:text-signal-500 dark:hover:text-signal-400 p-0.5 transition-colors" title="Move left">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                                </button>
                            }
                            @if (nextColumn is not null)
                            {
                                var next = nextColumn;
                                <button @onclick="() => MoveTask(task, columnId, next)"
                                        class="text-canvas-400 dark:text-canvas-500 hover:text-signal-500 dark:hover:text-signal-400 p-0.5 transition-colors" title="Move right">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
} }
