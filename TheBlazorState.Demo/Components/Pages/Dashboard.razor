@page "/"

<PageTitle>Dashboard — TaskFlow</PageTitle>

<div class="mb-6 animate-fade-up">
    <h1 class="font-display text-2xl font-bold text-canvas-900 dark:text-canvas-50">Dashboard</h1>
    <p class="text-sm text-canvas-500 dark:text-canvas-500 mt-1">@Project.SelectedProject.Name project overview</p>
</div>

<TryItHint Id="dashboard" Text="Wait 2 minutes for TTL expiry (a stale banner appears), or refresh the page to see prerender cache restore in action." />

@if (Stats is null)
{
    <div class="flex items-center gap-3 text-canvas-400 dark:text-canvas-600 py-12">
        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
        <span class="font-mono text-sm">Loading dashboard...</span>
    </div>
}
else
{
    @if (StatsMeta.IsStale)
    {
        <div class="mb-6 flex items-center gap-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-300 px-4 py-3 rounded-lg text-sm animate-fade-up">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <span>Data is stale — last updated <span class="font-mono">@StatsMeta.LastUpdated.LocalDateTime.ToString("HH:mm:ss")</span></span>
            <button @onclick="Refresh" class="ml-auto font-medium text-amber-700 dark:text-amber-400 hover:underline underline-offset-2">Refresh</button>
        </div>
    }

    @if (StatsMeta.WasRestored)
    {
        <div class="mb-6 flex items-center gap-2 text-xs text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 px-3 py-2 rounded-lg animate-fade-up">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="font-mono">Restored from prerender cache — no redundant API call</span>
        </div>
    }

    <!-- Stat Cards -->
    <div class="grid grid-cols-3 gap-5 mb-8">
        <div class="animate-fade-up stagger-1 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5 relative overflow-hidden group hover:border-canvas-300 dark:hover:border-canvas-700 transition-colors">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-canvas-200 dark:bg-canvas-700"></div>
            <p class="text-xs font-mono font-medium text-canvas-400 dark:text-canvas-500 uppercase tracking-wider">Total Tasks</p>
            <p class="font-display text-3xl font-bold text-canvas-900 dark:text-canvas-50 mt-2">@Stats.TotalTasks</p>
        </div>
        <div class="animate-fade-up stagger-2 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5 relative overflow-hidden group hover:border-signal-300 dark:hover:border-signal-800 transition-colors">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-signal-400"></div>
            <p class="text-xs font-mono font-medium text-canvas-400 dark:text-canvas-500 uppercase tracking-wider">In Progress</p>
            <p class="font-display text-3xl font-bold text-signal-600 dark:text-signal-400 mt-2">@Stats.InProgress</p>
        </div>
        <div class="animate-fade-up stagger-3 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 p-5 relative overflow-hidden group hover:border-emerald-300 dark:hover:border-emerald-800 transition-colors">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-emerald-400"></div>
            <p class="text-xs font-mono font-medium text-canvas-400 dark:text-canvas-500 uppercase tracking-wider">Completed</p>
            <p class="font-display text-3xl font-bold text-emerald-600 dark:text-emerald-400 mt-2">@Stats.Completed</p>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="animate-fade-up stagger-4 bg-white dark:bg-canvas-900 rounded-xl border border-canvas-200 dark:border-canvas-800 overflow-hidden">
        <div class="px-5 py-4 border-b border-canvas-100 dark:border-canvas-800">
            <h2 class="text-xs font-mono font-semibold text-canvas-500 dark:text-canvas-400 uppercase tracking-wider">Recent Activity</h2>
        </div>
        <ul class="divide-y divide-canvas-100 dark:divide-canvas-800">
            @foreach (var activity in Stats.RecentActivity)
            {
                <li class="px-5 py-3 flex items-center justify-between hover:bg-canvas-50 dark:hover:bg-canvas-800/50 transition-colors">
                    <div>
                        <span class="text-sm text-canvas-800 dark:text-canvas-200 font-medium">@activity.TaskTitle</span>
                        <span class="text-sm text-canvas-400 dark:text-canvas-500 ml-1.5">@activity.Action by @activity.Actor</span>
                    </div>
                    <span class="text-xs font-mono text-canvas-400 dark:text-canvas-600">@FormatRelativeTime(activity.Timestamp)</span>
                </li>
            }
        </ul>
    </div>

    <CodeSnippet Title="View source: Persist + TTL + Prerender Cache"
                 Code="<span class='text-signal-400'>[Persist(TimeToLive = &quot;00:02:00&quot;)]</span>
<span class='text-emerald-400'>public partial</span> DashboardData? <span class='text-sky-400'>Stats</span> { get; set; }

<span class='text-canvas-500'>// ConfigureState — runs during OnInitialized</span>
<span class='text-emerald-400'>partial void</span> ConfigureState(__StateContext ctx)
{
    ctx.Stats
        .<span class='text-sky-400'>KeySuffix</span>(Project.SelectedProject.Id)
        .<span class='text-sky-400'>LoadFrom</span>(<span class='text-emerald-400'>async</span> () =&gt;
            <span class='text-emerald-400'>await</span> StatsService.GetDashboardAsync(id));
}" />
}
