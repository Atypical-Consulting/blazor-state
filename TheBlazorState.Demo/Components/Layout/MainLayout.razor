@inherits LayoutComponentBase

<div class="flex min-h-screen">
    <!-- Mobile top bar -->
    <div class="md:hidden flex items-center gap-3 px-4 py-3 border-b border-canvas-200 dark:border-canvas-800 bg-white dark:bg-canvas-900 fixed top-0 left-0 right-0 z-30">
        <button @onclick="ToggleSidebar" class="p-1 text-canvas-500 dark:text-canvas-400 hover:text-canvas-900 dark:hover:text-canvas-100 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div class="flex items-center gap-2">
            <div class="relative flex items-center justify-center w-6 h-6 rounded-md bg-signal-500/10 dark:bg-signal-500/15">
                <svg class="w-3.5 h-3.5 text-signal-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M2 12h4l3-9 6 18 3-9h4" /></svg>
            </div>
            <span class="font-display text-sm font-bold text-canvas-900 dark:text-canvas-50 tracking-tight">TaskFlow</span>
        </div>
    </div>

    <!-- Mobile backdrop -->
    @if (_sidebarOpen)
    {
        <div class="md:hidden fixed inset-0 z-40 bg-black/50 backdrop-blur-sm animate-fade-up" @onclick="ToggleSidebar"></div>
    }

    <!-- Sidebar -->
    <div class="@(_sidebarOpen ? "fixed inset-y-0 left-0 z-50 flex" : "hidden") md:flex md:relative md:z-auto">
        <Sidebar OnClose="@ToggleSidebar" />
    </div>

    <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 dark:bg-gray-900 pt-14 md:pt-0 pb-16">
        <div class="max-w-6xl mx-auto px-4 md:px-8 py-6 md:py-8">
            @Body
        </div>
    </main>
</div>

<StateInspector />