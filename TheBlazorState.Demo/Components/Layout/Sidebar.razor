<aside class="w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col h-screen sticky top-0">
    <!-- Logo -->
    <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700">
        <h1 class="text-lg font-bold text-slate-900 dark:text-gray-100 tracking-tight">TaskFlow</h1>
        <p class="text-xs text-slate-400 dark:text-gray-500 mt-0.5">TheBlazorState Demo</p>
    </div>

    <!-- Projects -->
    <div class="px-3 py-4">
        <p class="px-2 mb-2 text-xs font-semibold text-slate-400 dark:text-gray-500 uppercase tracking-wider">Projects</p>
        @foreach (var project in ProjectSvc.GetAll())
        {
            var isActive = ProjectState.SelectedProject.Id == project.Id;
            <button @onclick="() => SelectProject(project)"
                    class="@($"w-full text-left px-3 py-2 rounded-lg text-sm mb-0.5 flex items-center gap-2.5 transition-colors {(isActive ? "bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-medium" : "text-slate-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")}")">
                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: @project.Color"></span>
                @project.Name
            </button>
        }
    </div>

    <!-- Navigation -->
    <div class="px-3 py-2 border-t border-gray-100 dark:border-gray-700">
        <p class="px-2 mb-2 text-xs font-semibold text-slate-400 dark:text-gray-500 uppercase tracking-wider">Views</p>
        <NavLink href="" Match="NavLinkMatch.All"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                 ActiveClass="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            Dashboard
        </NavLink>
        <NavLink href="board"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                 ActiveClass="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
            Board
        </NavLink>
        <NavLink href="settings"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                 ActiveClass="bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Settings
        </NavLink>
    </div>

    <!-- Footer -->
    <div class="mt-auto px-5 py-4 border-t border-gray-100 dark:border-gray-700">
        <p class="text-xs text-slate-400 dark:text-gray-500">Powered by <span class="font-medium text-indigo-500">TheBlazorState</span></p>
    </div>
</aside>
