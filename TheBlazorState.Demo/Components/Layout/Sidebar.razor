<aside class="w-64 bg-white dark:bg-canvas-900 border-r border-canvas-200 dark:border-canvas-800 flex flex-col h-screen sticky top-0">
    <!-- Brand -->
    <div class="px-5 py-5 border-b border-canvas-100 dark:border-canvas-800">
        <div class="flex items-center gap-3">
            <!-- Signal logo mark -->
            <div class="relative flex items-center justify-center w-8 h-8 rounded-lg bg-signal-500/10 dark:bg-signal-500/15">
                <svg class="w-4.5 h-4.5 text-signal-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <path d="M2 12h4l3-9 6 18 3-9h4" />
                </svg>
                <span class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-signal-400 animate-signal"></span>
            </div>
            <div class="flex-1">
                <h1 class="font-display text-base font-bold text-canvas-900 dark:text-canvas-50 tracking-tight">TaskFlow</h1>
                <p class="text-[10px] font-mono text-canvas-400 dark:text-canvas-600 tracking-wider uppercase">TheBlazorState</p>
            </div>
            <!-- Mobile close button -->
            <button @onclick="OnClose" class="md:hidden p-1 text-canvas-400 dark:text-canvas-500 hover:text-canvas-900 dark:hover:text-canvas-100 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
    </div>

    <!-- Projects -->
    <div class="px-3 py-4">
        <p class="px-2 mb-2 text-[10px] font-mono font-medium text-canvas-400 dark:text-canvas-600 uppercase tracking-widest">Projects</p>
        @foreach (var project in ProjectSvc.GetAll())
        {
            var isActive = ProjectState.SelectedProject.Id == project.Id;
            <button @onclick="() => SelectProject(project)"
                    class="@($"w-full text-left px-3 py-2 rounded-lg text-sm mb-0.5 flex items-center gap-2.5 transition-all duration-150 {(isActive ? "bg-signal-50 dark:bg-signal-500/10 text-signal-700 dark:text-signal-400 font-medium" : "text-canvas-600 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200")}")">
                <span class="w-2 h-2 rounded-full flex-shrink-0 ring-2 ring-offset-1 dark:ring-offset-canvas-900 transition-all duration-150 @(isActive ? "ring-signal-400/50" : "ring-transparent")" style="background-color: @project.Color"></span>
                @project.Name
            </button>
        }
    </div>

    <!-- Navigation -->
    <div class="px-3 py-2 border-t border-canvas-100 dark:border-canvas-800">
        <p class="px-2 mb-2 text-[10px] font-mono font-medium text-canvas-400 dark:text-canvas-600 uppercase tracking-widest">Views</p>
        <NavLink href="" Match="NavLinkMatch.All"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-canvas-500 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200 transition-all duration-150"
                 ActiveClass="nav-active bg-canvas-50 dark:bg-canvas-800 text-canvas-900 dark:text-canvas-100 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            Dashboard
        </NavLink>
        <NavLink href="board"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-canvas-500 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200 transition-all duration-150"
                 ActiveClass="nav-active bg-canvas-50 dark:bg-canvas-800 text-canvas-900 dark:text-canvas-100 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
            Board
        </NavLink>
        <NavLink href="cross-tab"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-canvas-500 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200 transition-all duration-150"
                 ActiveClass="nav-active bg-canvas-50 dark:bg-canvas-800 text-canvas-900 dark:text-canvas-100 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            Cross-Tab Sync
        </NavLink>
        <NavLink href="storage-compare"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-canvas-500 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200 transition-all duration-150"
                 ActiveClass="nav-active bg-canvas-50 dark:bg-canvas-800 text-canvas-900 dark:text-canvas-100 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7c-2 0-3 1-3 3zm0 5h16"/></svg>
            Storage Strategies
        </NavLink>
        <NavLink href="headless"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-canvas-500 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200 transition-all duration-150"
                 ActiveClass="nav-active bg-canvas-50 dark:bg-canvas-800 text-canvas-900 dark:text-canvas-100 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            Headless UI
        </NavLink>
        <NavLink href="settings"
                 class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-canvas-500 dark:text-canvas-400 hover:bg-canvas-50 dark:hover:bg-canvas-800 hover:text-canvas-900 dark:hover:text-canvas-200 transition-all duration-150"
                 ActiveClass="nav-active bg-canvas-50 dark:bg-canvas-800 text-canvas-900 dark:text-canvas-100 font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.11 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Settings
        </NavLink>
    </div>

    <!-- Footer -->
    <div class="mt-auto px-3 py-4 border-t border-canvas-100 dark:border-canvas-800 space-y-3">
        <button @onclick="ResetAllState"
                class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-mono
                       text-canvas-400 dark:text-canvas-500 hover:text-rose-500 dark:hover:text-rose-400
                       hover:bg-rose-50 dark:hover:bg-rose-900/20 transition-all duration-150">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Reset All State
        </button>
        <div class="flex items-center gap-2 px-2">
            <span class="w-1.5 h-1.5 rounded-full bg-signal-500 animate-signal"></span>
            <p class="text-xs text-canvas-400 dark:text-canvas-500">
                Powered by <span class="font-mono font-medium text-signal-600 dark:text-signal-400">TheBlazorState</span>
            </p>
        </div>
    </div>
</aside>
