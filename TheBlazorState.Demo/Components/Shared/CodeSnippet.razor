@if (!_open)
{
    <button @onclick="Toggle"
            class="mt-6 mb-2 flex items-center gap-2 text-xs font-mono text-canvas-400 dark:text-canvas-500 hover:text-signal-500 dark:hover:text-signal-400 transition-colors animate-fade-up">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        @Title
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
}
else
{
    <div class="mt-6 mb-2 animate-fade-up">
        <button @onclick="Toggle"
                class="flex items-center gap-2 text-xs font-mono text-signal-500 dark:text-signal-400 mb-3 hover:text-signal-600 dark:hover:text-signal-300 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            @Title
            <svg class="w-3 h-3 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="bg-canvas-950 rounded-xl border border-canvas-800 overflow-hidden">
            <div class="p-4 overflow-x-auto">
                <pre class="font-mono text-xs leading-relaxed text-canvas-300">@((MarkupString)Code)</pre>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string Code { get; set; } = "";

    private bool _open;

    private void Toggle() => _open = !_open;
}
