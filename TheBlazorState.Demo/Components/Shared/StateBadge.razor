@if (Value)
{
    <span class="@($"inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-mono font-medium tracking-wide {TrueClass}")">@TrueLabel</span>
}
else
{
    <span class="@($"inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-mono font-medium tracking-wide {FalseClass}")">@FalseLabel</span>
}

@code {
    [Parameter, EditorRequired] public bool Value { get; set; }
    [Parameter] public string TrueLabel { get; set; } = "Yes";
    [Parameter] public string FalseLabel { get; set; } = "No";
    [Parameter] public string TrueClass { get; set; } = "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400";
    [Parameter] public string FalseClass { get; set; } = "bg-canvas-100 dark:bg-canvas-800 text-canvas-500 dark:text-canvas-500";
}
