@implements IDisposable

@if (!_open)
{
    <!-- Floating trigger button -->
    <button @onclick="Open"
            class="fixed bottom-4 right-4 z-40 flex items-center gap-2 px-3 py-2 rounded-lg
                   bg-canvas-900 dark:bg-canvas-800 text-canvas-200 dark:text-canvas-300
                   border border-canvas-700 dark:border-canvas-700
                   shadow-lg hover:bg-canvas-800 dark:hover:bg-canvas-700 transition-all duration-200
                   font-mono text-xs">
        <svg class="w-4 h-4 text-signal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        @if (_hasRestored)
        {
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-signal"></span>
        }
        <span>State Inspector</span>
        <span class="bg-canvas-700 dark:bg-canvas-600 px-1.5 py-0.5 rounded text-[10px]">@_entries.Count</span>
    </button>
}
else
{
    <!-- Floating bottom panel -->
    <div class="fixed bottom-0 left-0 right-0 md:left-64 z-40 animate-slide-up">
        <div class="bg-canvas-900 dark:bg-canvas-950 border-t border-canvas-700 dark:border-canvas-800 shadow-2xl">
            <!-- Header -->
            <div class="flex items-center justify-between px-4 py-2 border-b border-canvas-800 dark:border-canvas-800">
                <span class="font-mono text-xs font-semibold text-canvas-400 dark:text-canvas-400 flex items-center gap-2 uppercase tracking-wider">
                    <svg class="w-4 h-4 text-signal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                    State Inspector
                    <span class="bg-canvas-700 px-1.5 py-0.5 rounded text-[10px] text-canvas-300">@_entries.Count properties</span>
                </span>
                <button @onclick="Close" class="p-1 text-canvas-500 hover:text-canvas-300 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </button>
            </div>
            <!-- Table -->
            <div class="max-h-64 overflow-y-auto p-4">
                @if (_entries.Count == 0)
                {
                    <p class="text-xs font-mono text-canvas-500 text-center py-4">No state properties registered on this page</p>
                }
                else
                {
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-[10px] font-mono text-canvas-500 uppercase tracking-widest">
                                <th class="pb-2 pr-4">Property</th>
                                <th class="pb-2 pr-4">Storage</th>
                                <th class="pb-2 pr-4">Restored</th>
                                <th class="pb-2 pr-4">Dirty</th>
                                <th class="pb-2 pr-4">Stale</th>
                                <th class="pb-2">Last Updated</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-canvas-800">
                            @foreach (var entry in _entries)
                            {
                                <tr class="hover:bg-canvas-800/50 transition-colors">
                                    <td class="py-2 pr-4 font-mono text-xs font-medium text-canvas-300">@entry.Name</td>
                                    <td class="py-2 pr-4 font-mono text-xs text-canvas-500">@entry.Strategy</td>
                                    <td class="py-2 pr-4"><StateBadge Value="entry.Meta.WasRestored" TrueLabel="Restored" FalseLabel="Fresh" /></td>
                                    <td class="py-2 pr-4"><StateBadge Value="entry.Meta.IsDirty" TrueLabel="Dirty" FalseLabel="Clean" TrueClass="bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400" /></td>
                                    <td class="py-2 pr-4"><StateBadge Value="entry.Meta.IsStale" TrueLabel="Stale" FalseLabel="Fresh" TrueClass="bg-rose-100 dark:bg-rose-900/30 text-rose-700 dark:text-rose-400" /></td>
                                    <td class="py-2 font-mono text-xs text-canvas-500">@FormatTime(entry.Meta.LastUpdated)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
}
